PORT=8000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=replace_me
DB_NAME=task_management
DB_PORT=3306

# Optional Redis response cache. MySQL remains authoritative and the API
# automatically bypasses caching when Redis is disabled or unavailable.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=taskflow
REDIS_DEFAULT_TTL=60
REDIS_TTL_JITTER_SECONDS=10

# Authentication
JWT_SECRET=replace_with_a_long_random_value
JWT_REFRESH_SECRET=replace_with_a_different_long_random_value
JWT_TEMP_SECRET=replace_with_another_long_random_value

# Payment-gated SaaS signup
STRIPE_SECRET_KEY=sk_test_replace_me
# No publishable key is required for the hosted Checkout redirect used here.
# Add one to the frontend only for Stripe.js, Elements, or embedded Checkout.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_with_a_separate_webhook_secret
RAZORPAY_USD_TO_INR=83
SAAS_LANDING_URL=http://localhost:5173
CLIENT_APP_URL=http://localhost:3000
# Leave COOKIE_DOMAIN empty on localhost. In production use the shared parent,
# for example: .taskflow.com (for app.taskflow.com and api.taskflow.com).
COOKIE_DOMAIN=
ONBOARDING_HANDOFF_TTL_MINUTES=10

# Optional media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
